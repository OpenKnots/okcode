---
/**
 * Stats bar — metrics section for visual credibility.
 */
interface Props {
  metrics: ReadonlyArray<{ value: string; label: string }>;
}

const { metrics } = Astro.props;
---

<section class="stats-bar" data-reveal data-reveal-children>
  {metrics.map((metric) => (
    <div class="stat-item">
      <span class="stat-value">{metric.value}</span>
      <span class="stat-label">{metric.label}</span>
    </div>
  ))}
</section>

<style>
  .stats-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    margin-bottom: var(--kn-landing-section-gap, clamp(5rem, 8vw, 8rem));
    padding: 2.5rem 2rem;
    border-radius: 1.5rem;
    border: 1px solid var(--kn-landing-border, rgba(192, 200, 212, 0.08));
    background: var(--kn-landing-card-bg, rgba(192, 200, 212, 0.02));
    backdrop-filter: blur(18px);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 24px 80px rgba(0, 0, 0, 0.2);
  }

  .stat-item {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.5rem;
    position: relative;
  }

  .stat-item + .stat-item::before {
    content: "";
    position: absolute;
    left: 0;
    top: 15%;
    height: 70%;
    width: 1px;
    background: linear-gradient(180deg, transparent, var(--kn-landing-border, rgba(192, 200, 212, 0.08)), transparent);
  }

  .stat-value {
    font-size: clamp(2.25rem, 4vw, 3.5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    background: linear-gradient(135deg, var(--kn-landing-text, #e8ecf0), var(--kn-landing-accent-bright, #ff4e41));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .stat-label {
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--kn-landing-text-muted, #8a94a4);
    font-weight: 500;
  }

  @media (max-width: 720px) {
    .stats-bar {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
      padding: 2rem 1.5rem;
    }

    .stat-item + .stat-item::before {
      display: none;
    }
  }
</style>
