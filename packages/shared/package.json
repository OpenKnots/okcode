      "import": "./src/git.ts"
    },
    "./logging": {
      "types": "./src/logging.ts",
      "import": "./src/logging.ts"
    },
    "./shell": {
      "types": "./src/shell.ts",
      "import": "./src/shell.ts"
    },
    "./Net": {
      "types": "./src/Net.ts",
      "import": "./src/Net.ts"
    },
    "./DrainableWorker": {
      "types": "./src/DrainableWorker.ts",
      "import": "./src/DrainableWorker.ts"
    },
    "./schemaJson": {
      "types": "./src/schemaJson.ts",
      "import": "./src/schemaJson.ts"
    },
    "./preview": {
      "types": "./src/preview.ts",
      "import": "./src/preview.ts"
    },
    "./environment": {
