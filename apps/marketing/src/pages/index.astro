---

<Layout title="OK Code" {description}>
  <Hero />
  <LogoCloud />
  <TrustStrip />
  <StatsBar metrics={metrics} />
  <FeatureGrid pillars={pillars} />
  <WorkflowSection steps={workflowSteps} />
  <CoreSurfaces surfaces={surfaces} />
  <ThemeShowcase themes={themes} />
  <FaqSection faqs={faqs} />
  <FinalCta />
</Layout>

<script>
  import {
    fetchLatestRelease,
    RELEASES_URL,
    type Release,
  } from "../lib/releases";
  import { detectPlatform, pickAsset } from "../lib/download";

  function initDownloadButton() {
    const btn = document.getElementById("download-btn") as HTMLAnchorElement | null;
    const label = document.getElementById("download-label");
    if (!btn || !label) return;

    const platform = detectPlatform(navigator.userAgent);
    if (!platform) return;

    document.documentElement.dataset.platform = platform.os;
    label.textContent = platform.label;

    fetchLatestRelease()
      .then((release: Release) => {
        const url = pickAsset(release.assets ?? [], platform);
        if (url) {
          btn.href = url;
          btn.removeAttribute("target");
          btn.removeAttribute("rel");
        }
      })
      .catch(() => {
        btn.href = RELEASES_URL;
      });
  }

  /**
   * Tab groups with:
   * - CSS crossfade transitions (opacity + transform) instead of instant hidden toggle
   * - Full keyboard navigation (Arrow keys, Home, End) per WAI-ARIA Tabs pattern
   */
  function initTabGroups() {
    const groups = document.querySelectorAll<HTMLElement>("[data-tab-group]");
    groups.forEach((group) => {
      const defaultTab = group.getAttribute("data-tab-default");
      const buttons = Array.from(group.querySelectorAll<HTMLElement>("[data-tab-button]"));
      const panels = Array.from(group.querySelectorAll<HTMLElement>("[data-tab-panel]"));

      const activate = (id: string, focusButton = false) => {
        buttons.forEach((button) => {
          const isActive = button.getAttribute("data-tab-target") === id;
          button.setAttribute("aria-selected", isActive ? "true" : "false");
          button.setAttribute("tabindex", isActive ? "0" : "-1");
          button.dataset.active = isActive ? "true" : "false";
          if (isActive && focusButton) button.focus();
        });

        panels.forEach((panel) => {
          const isActive = panel.getAttribute("data-tab-panel") === id;
          panel.setAttribute("aria-hidden", isActive ? "false" : "true");
          panel.dataset.active = isActive ? "true" : "false";
        });

        group.setAttribute("data-active-tab", id);
      };

      // Click activation
      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          const id = button.getAttribute("data-tab-target");
          if (id) activate(id);
        });
      });

      // Keyboard navigation (WAI-ARIA Tabs pattern)
      buttons.forEach((button) => {
        button.addEventListener("keydown", (e: KeyboardEvent) => {
          const currentIndex = buttons.indexOf(button);
          let targetIndex = -1;

          switch (e.key) {
            case "ArrowRight":
            case "ArrowDown":
              e.preventDefault();
              targetIndex = (currentIndex + 1) % buttons.length;
              break;
            case "ArrowLeft":
            case "ArrowUp":
              e.preventDefault();
              targetIndex = (currentIndex - 1 + buttons.length) % buttons.length;
              break;
            case "Home":
              e.preventDefault();
              targetIndex = 0;
              break;
            case "End":
              e.preventDefault();
              targetIndex = buttons.length - 1;
              break;
          }

          if (targetIndex >= 0) {
            const id = buttons[targetIndex]?.getAttribute("data-tab-target");
            if (id) activate(id, true);
          }
        });
      });

      if (defaultTab) activate(defaultTab);
    });
  }

  /**
   * IntersectionObserver-based scroll reveal — replaces hardcoded cascade delays
   * so below-fold sections only animate in when they enter the viewport.
   */
  function initScrollReveal() {
    const sections = document.querySelectorAll<HTMLElement>("[data-reveal]");
    if (!sections.length) return;

    // Respect reduced motion preference
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (prefersReducedMotion) {
      sections.forEach((el) => {
        el.classList.add("revealed");
      });
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("revealed");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.08, rootMargin: "0px 0px -40px 0px" },
    );

    sections.forEach((el) => observer.observe(el));
  }

  function initFaqAccordion() {
    const root = document.querySelector<HTMLElement>("[data-faq-root]");
    if (!root) return;

    const items = Array.from(root.querySelectorAll<HTMLElement>("[data-faq-item]"));

    const setOpen = (targetIndex: number) => {
      items.forEach((item, index) => {
        const trigger = item.querySelector<HTMLButtonElement>("[data-faq-trigger]");
        const panel = item.querySelector<HTMLElement>("[data-faq-panel]");
        const isOpen = index === targetIndex;
        if (!trigger || !panel) return;

        trigger.setAttribute("aria-expanded", String(isOpen));
        item.dataset.open = String(isOpen);
        panel.setAttribute("aria-hidden", String(!isOpen));
        panel.style.maxHeight = isOpen ? `${panel.scrollHeight}px` : "0px";
        panel.style.opacity = isOpen ? "1" : "0";
      });
    };

    items.forEach((item, index) => {
      const trigger = item.querySelector<HTMLButtonElement>("[data-faq-trigger]");
      if (!trigger) return;
      trigger.addEventListener("click", () => {
        const expanded = trigger.getAttribute("aria-expanded") === "true";
        setOpen(expanded ? -1 : index);
      });
    });

    const initiallyOpen = items.findIndex((item) => item.querySelector("[data-faq-trigger]")?.getAttribute("aria-expanded") === "true");
    setOpen(initiallyOpen >= 0 ? initiallyOpen : -1);

    window.addEventListener("resize", () => {
      const openIndex = items.findIndex((item) => item.dataset.open === "true");
      if (openIndex >= 0) setOpen(openIndex);
    });
  }

  /** Hero button shine sweep on page load */
  function initHeroShine() {
    const shine = document.querySelector<HTMLElement>(".hero-button-shine");
    if (!shine) return;
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (prefersReducedMotion) return;
    setTimeout(() => shine.classList.add("shine-entered"), 1500);
  }

  /** Subtle scroll parallax on the hero visual stage */
  function initHeroParallax() {
    const stage = document.querySelector<HTMLElement>(".hero-visual-stage");
    if (!stage) return;
    const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    if (prefersReducedMotion) return;
    const isMobile = window.matchMedia("(max-width: 720px)").matches;
    if (isMobile) return;

    let ticking = false;
    window.addEventListener("scroll", () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const y = window.scrollY * 0.15;
          stage.style.transform = `perspective(2400px) rotateX(2deg) translateY(${y}px)`;
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  }

  initDownloadButton();
  initTabGroups();
  initScrollReveal();
  initFaqAccordion();
  initHeroShine();
  initHeroParallax();
</script>

<style>
  /* ── Scroll-triggered reveal ── */

  :global([data-reveal]) {
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: opacity, transform;
  }

  :global([data-reveal].revealed) {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Tab panel crossfade transitions ── */

  :global([data-tab-panel]) {
    opacity: 0;
    transform: translateY(6px);
    transition:
      opacity 0.35s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    position: absolute;
    pointer-events: none;
    visibility: hidden;
  }

  :global([data-tab-panel][data-active="true"]) {
    opacity: 1;
    transform: translateY(0);
    position: relative;
    pointer-events: auto;
    visibility: visible;
  }

  /* ── Below-fold paint optimization ── */

  :global(.workflow-section),
  :global(.spotlight),
  :global(.theme-section),
  :global(.faq-section),
  :global(.final-cta-wrap) {
    content-visibility: auto;
    contain-intrinsic-size: auto 32rem;
  }

  .main {
    width: 100%;
    padding-block: 3.5rem 5.5rem;
  }

  :global(.hero),
  :global(.trust-strip),
  :global(.feature-grid),
  :global(.workflow-section),
  :global(.spotlight),
  :global(.theme-section),
  :global(.faq-section),
  :global(.final-cta),
  :global(.final-cta-wrap) {
    width: 100%;
  }

  :global(.hero) {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
    justify-items: center;
    margin-bottom: clamp(4rem, 8vw, 7rem);
    padding-top: clamp(3rem, 8vw, 6rem);
  }

  :global(.hero-copy) {
    position: relative;
    z-index: 1;
    width: min(100%, 62rem);
  }

  :global(.hero-copy--centered),
  :global(.hero-actions--centered),
  :global(.hero-meta--centered) {
    justify-content: center;
    text-align: center;
  }

  :global(.hero-copy--centered) {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  :global(.eyebrow) {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.55rem 0.9rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.04);
    color: rgba(255, 255, 255, 0.8);
    font-size: 0.84rem;
    letter-spacing: 0.01em;
    backdrop-filter: blur(18px);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06);
    margin-bottom: 1.35rem;
  }

  :global(.eyebrow-dot) {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #67e8f9, #a855f7);
    box-shadow: 0 0 18px rgba(103, 232, 249, 0.55);
  }

  :global(.hero-mark) {
    position: relative;
    display: grid;
    place-items: center;
    width: clamp(7rem, 15vw, 10rem);
    height: clamp(7rem, 15vw, 10rem);
    margin: 0.5rem 0 1.25rem;
  }

  :global(.hero-mark-glow) {
    position: absolute;
    inset: auto;
    border-radius: 999px;
    filter: blur(30px);
    pointer-events: none;
  }

  :global(.hero-mark-glow--violet) {
    width: 9rem;
    height: 9rem;
    background: radial-gradient(circle, rgba(192, 200, 212, 0.22), transparent 72%);
  }

  :global(.hero-mark-glow--cyan) {
    width: 11rem;
    height: 11rem;
    background: radial-gradient(circle, rgba(202, 58, 41, 0.16), transparent 74%);
  }

  :global(.hero-mark-core) {
    position: relative;
    z-index: 1;
    width: clamp(5rem, 10vw, 6.25rem);
    height: clamp(5rem, 10vw, 6.25rem);
    border-radius: 1.7rem;
    display: grid;
    place-items: center;
    background: linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.02));
    border: 1px solid rgba(192, 200, 212, 0.14);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255,255,255,0.08);
    backdrop-filter: blur(20px);
  }

  :global(.hero-mark-core img) {
    width: 56%;
    height: auto;
    filter: drop-shadow(0 0 24px rgba(202, 58, 41, 0.2));
  }

  :global(.tagline) {
    font-size: clamp(3.2rem, 7vw, 6.2rem);
    line-height: 0.92;
    letter-spacing: -0.07em;
    max-width: 12ch;
    text-wrap: balance;
    margin-inline: auto;
  }

  :global(.subtagline) {
    margin-top: 1.35rem;
    max-width: 46rem;
    font-size: clamp(1.06rem, 1.5vw, 1.28rem);
    line-height: 1.72;
    color: rgba(232, 236, 240, 0.75);
    margin-inline: auto;
  }

  :global(.hero-actions),
  :global(.hero-meta),
  :global(.hero-pills),
  :global(.trust-strip),
  :global(.workflow-grid),
  :global(.spotlight),
  :global(.theme-preview),
  :global(.faq-grid),
  :global(.final-cta-actions),
  :global(.tab-row),
  :global(.panel-row),
  :global(.traffic-lights),
  :global(.theme-preview-bar),
  :global(.theme-preview-body) {
    display: flex;
  }

  :global(.hero-actions) {
    gap: 0.95rem;
    margin-top: 1.8rem;
    flex-wrap: wrap;
  }

  :global(.hero-button),
  :global(.secondary-button),
  :global(.tab-chip),
  :global(.spotlight-item) {
    transition:
      transform 0.24s ease,
      border-color 0.24s ease,
      background 0.24s ease,
      color 0.24s ease,
      box-shadow 0.24s ease;
  }

  :global(.hero-button),
  :global(.secondary-button) {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    min-height: 3.4rem;
    padding: 0.95rem 1.2rem;
    border-radius: 1rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    overflow: hidden;
  }

  :global(.hero-button) {
    border: 1px solid rgba(192, 200, 212, 0.22);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.03)),
      linear-gradient(135deg, rgba(202, 58, 41, 0.94), rgba(154, 45, 31, 0.96));
    color: #ffffff;
    box-shadow:
      0 14px 54px rgba(202, 58, 41, 0.22),
      0 0 28px rgba(192, 200, 212, 0.06),
      inset 0 1px 0 rgba(255, 255, 255, 0.18);
  }

  :global(.hero-button-shine) {
    content: "";
    position: absolute;
    inset: -30% auto auto -20%;
    width: 45%;
    height: 180%;
    transform: rotate(24deg) translateX(0);
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.18), transparent);
    pointer-events: none;
    transition: transform 0.45s ease;
  }

  :global(.secondary-button) {
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.03);
    color: rgba(250, 250, 250, 0.84);
    backdrop-filter: blur(18px);
  }

  :global(.hero-button:hover),
  :global(.secondary-button:hover),
  :global(.tab-chip:hover),
  :global(.spotlight-item:hover) {
    transform: translateY(-1px);
  }

  :global(.hero-button:hover .hero-button-shine) {
    transform: rotate(24deg) translateX(1.4rem);
  }

  :global(.hero-meta) {
    gap: 1rem;
    align-items: center;
    margin-top: 1.35rem;
    flex-wrap: wrap;
  }

  :global(.other-platforms) {
    color: rgba(255, 255, 255, 0.62);
    font-size: 0.94rem;
  }

  :global(.other-platforms:hover) {
    color: rgba(255, 255, 255, 0.88);
  }

  :global(.hero-pills) {
    gap: 0.65rem;
    flex-wrap: wrap;
  }

  :global(.hero-pills span),
  :global(.trust-item),
  :global(.feature-card),
  :global(.workflow-card),
  :global(.spotlight-panel),
  :global(.faq-card),
  :global(.meta-card) {
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.05),
      0 22px 60px rgba(0, 0, 0, 0.26);
    backdrop-filter: blur(18px);
  }

  :global(.hero-pills span) {
    padding: 0.55rem 0.8rem;
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.74);
    font-size: 0.86rem;
  }

  :global(.hero-visual) {
    position: relative;
    min-height: 42rem;
    display: grid;
    place-items: center;
  }

  :global(.hero-glow),
  :global(.orb) {
    position: absolute;
    border-radius: 999px;
    filter: blur(20px);
    pointer-events: none;
  }

  :global(.hero-glow--violet) {
    width: 26rem;
    height: 26rem;
    top: 1rem;
    right: 3rem;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.28), transparent 72%);
  }

  :global(.hero-glow--cyan) {
    width: 23rem;
    height: 23rem;
    bottom: 1rem;
    left: 2rem;
    background: radial-gradient(circle, rgba(34, 211, 238, 0.24), transparent 72%);
  }

  :global(.orb--one) {
    width: 10rem;
    height: 10rem;
    top: 8%;
    left: 10%;
    background: radial-gradient(circle, rgba(103, 232, 249, 0.22), transparent 68%);
  }

  :global(.orb--two) {
    width: 12rem;
    height: 12rem;
    right: 8%;
    bottom: 10%;
    background: radial-gradient(circle, rgba(217, 70, 239, 0.16), transparent 70%);
  }

  :global(.glass-stage) {
    position: relative;
    width: min(100%, 52rem);
    border-radius: 1.85rem;
