---
interface Props {
  steps: ReadonlyArray<{ step: string; title: string; body: string }>;
}

const { steps } = Astro.props;

const stepIcons = [
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M6 21V9a9 9 0 0 0 9 9"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>`,
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="18" height="18"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 3 0 3 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-3 0-3"/></svg>`
] as const;
---

<section class="workflow-section" aria-label="Workflow overview">
  <div class="section-heading" data-reveal>
    <p class="section-kicker">Workflow</p>
    <h2 class="section-title">From prompt to shipped change.</h2>
    <p class="section-body">
      OK Code keeps the whole loop visible: start the work, inspect the change, verify it,
      and move toward release without blowing up your focus.
    </p>
  </div>

  <div class="workflow-grid workflow-grid--cards">
    <div class="workflow-connector" aria-hidden="true"></div>
    {steps.map((item, index) => (
      <article class="workflow-card kn-card" data-reveal style={`transition-delay: ${index * 0.15}s`}>
        <div class="workflow-card-head">
          <span class="workflow-badge">
            <span class="workflow-badge-icon" set:html={stepIcons[index] ?? stepIcons[0]} />
          </span>
          <span class="workflow-step">{item.step}</span>
        </div>
        <h3>{item.title}</h3>
        <p>{item.body}</p>
      </article>
    ))}
  </div>
</section>
