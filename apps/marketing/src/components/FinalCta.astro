---
/**
 * Final CTA — bottom-of-page call to action with download + GitHub links.
 * Full-width dramatic closer with glow and breathing mark.
 */
---

<section class="final-cta-wrap" data-reveal>
  <div class="final-cta-glow" aria-hidden="true"></div>
  <div class="final-cta kn-card">
    <div class="final-cta-mark" aria-hidden="true">
      <div class="final-cta-mark-glow"></div>
      <img src="/icon.png" alt="" width="48" height="48" class="final-cta-mark-img" />
    </div>
    <p class="section-kicker">Ready</p>
    <h2>Stop building through tab chaos.</h2>
    <p>
      Bring chat, code review, preview, and release flow into one calm workspace built for serious
      AI-assisted work.
    </p>
    <div class="final-cta-actions">
      <a href="https://github.com/OpenKnots/okcode/releases" class="hero-button hero-button--lg">
        <span class="hero-button-shine" aria-hidden="true"></span>
        <span>Download OK Code</span>
      </a>
      <a
        href="https://github.com/OpenKnots/okcode"
        target="_blank"
        rel="noopener noreferrer"
        class="secondary-button"
      >
        Explore on GitHub
      </a>
    </div>
  </div>
</section>
