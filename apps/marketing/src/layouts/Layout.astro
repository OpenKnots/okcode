---
import "@fontsource-variable/dm-sans";
import Background from "../components/Background.astro";

interface Props {
  title?: string;
  description?: string;
  /** Path for og:image, relative to site root (requires PUBLIC_SITE_URL at build). */
  ogImagePath?: string;
}

const {
  title = "OK Code",
  description = "A minimal GUI for coding agents like Codex and Claude. Web and desktop.",
  ogImagePath = "/icon.png",
} = Astro.props;

const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : null;
const ogImage = Astro.site ? new URL(ogImagePath, Astro.site).href : null;
---

<html lang="en" data-theme="clawdash">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="application-name" content="OK Code" />
    <meta name="theme-color" content="#000000" />
    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon-16x16.png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "OK Code",
      "applicationCategory": "DeveloperApplication",
      "operatingSystem": "macOS, Windows, Linux",
      "description": description,
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "url": canonical ?? "https://okcode.dev"
    })} />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to content</a>

    <div class="kn-root">
      <Background />

      <header class="site-header" data-site-header>
        <nav class="kn-nav-inner content-wrap">
          <a href="/" class="kn-logo nav-brand">
            <img src="/icon.png" alt="" class="nav-icon" width="28" height="28" />
            <span class="nav-wordmark">OK Code</span>
          </a>

          <button
            class="kn-nav-toggle"
            data-nav-toggle
            aria-label="Toggle navigation"
            aria-expanded="false"
            type="button"
          >
            <span></span><span></span><span></span>
          </button>

          <div class="kn-nav-links" data-nav-drawer>
            <a href="#features" class="kn-nav-link">Features</a>
            <a href="#surfaces" class="kn-nav-link">Surfaces</a>
            <a href="#faq" class="kn-nav-link">FAQ</a>
            <a
              href="https://github.com/OpenKnots/okcode"
              target="_blank"
              rel="noopener noreferrer"
              class="kn-nav-signin"
            >
              GitHub
            </a>
          </div>
        </nav>
      </header>

      <main id="main-content" class="main">
        <div class="main-inner">
          <slot />
        </div>
      </main>

      <footer class="kn-footer">
        <div class="kn-footer-inner content-wrap">
          <div class="kn-footer-brand">
            <span class="kn-footer-mark">
              <img src="/icon.png" alt="" class="footer-icon" width="14" height="14" />
              OK Code
            </span>
            <p class="kn-footer-tagline">The beautiful workspace for shipping with AI.</p>
          </div>
          <div class="kn-footer-col">
            <span class="kn-footer-col-title">Product</span>
            <a href="#features">Features</a>
            <a href="#surfaces">Surfaces</a>
            <a href="/download">Download</a>
          </div>
          <div class="kn-footer-col">
            <span class="kn-footer-col-title">Community</span>
            <a href="https://github.com/OpenKnots/okcode" target="_blank" rel="noopener noreferrer">GitHub</a>
            <a href="https://discord.gg/jn4EGJjrvv" target="_blank" rel="noopener noreferrer">Discord</a>
          </div>
        </div>
        <div class="kn-footer-bottom content-wrap">
          <span>&copy; {new Date().getFullYear()} OpenKnots</span>
          <span>Built by <a href="https://github.com/OpenKnots" target="_blank" rel="noopener noreferrer">OpenKnots</a></span>
        </div>
      </footer>
    </div>

    <script>
      // Sticky header scroll effect
      const header = document.querySelector("[data-site-header]");
      if (header) {
        const onScroll = () => {
          header.classList.toggle("is-solid", window.scrollY > 36);
        };
        onScroll();
        window.addEventListener("scroll", onScroll, { passive: true });
      }

      // Mobile nav toggle
      const navToggle = document.querySelector<HTMLButtonElement>("[data-nav-toggle]");
      const navDrawer = document.querySelector<HTMLElement>("[data-nav-drawer]");
      if (navToggle && navDrawer) {
        navToggle.addEventListener("click", () => {
          const isOpen = navToggle.getAttribute("aria-expanded") === "true";
          navToggle.setAttribute("aria-expanded", String(!isOpen));
          navDrawer.classList.toggle("is-open", !isOpen);
          document.body.classList.toggle("nav-open", !isOpen);
        });

        // Close on link click
        navDrawer.querySelectorAll("a").forEach((link) => {
          link.addEventListener("click", () => {
            navToggle.setAttribute("aria-expanded", "false");
            navDrawer.classList.remove("is-open");
            document.body.classList.remove("nav-open");
          });
        });

        // Close on Escape
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape" && navDrawer.classList.contains("is-open")) {
            navToggle.setAttribute("aria-expanded", "false");
            navDrawer.classList.remove("is-open");
            document.body.classList.remove("nav-open");
            navToggle.focus();
          }
        });
      }

      // Active nav highlighting on scroll
      const navLinks = document.querySelectorAll<HTMLAnchorElement>(".kn-nav-link");
      const sections = document.querySelectorAll<HTMLElement>("section[id]");
      if (navLinks.length && sections.length) {
        const navObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const id = entry.target.id;
                navLinks.forEach((link) => {
                  link.classList.toggle("is-active", link.getAttribute("href") === `#${id}`);
                });
              }
            });
          },
          { threshold: 0.3, rootMargin: "-80px 0px -50% 0px" },
        );
        sections.forEach((s) => navObserver.observe(s));
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    --marketing-content-max: 1680px;
    --marketing-pad-x: clamp(1.25rem, 4vw, 3rem);

    --radius-xs: 4px;
    --radius-sm: 8px;
    --radius-md: 12px;
    --radius-lg: 16px;
    --radius-xl: 24px;
    --radius-full: 9999px;

    --kn-landing-bg: #050507;
    --kn-landing-text: #e8ecf0;
    --kn-landing-text-secondary: #c0c8d4;
    --kn-landing-text-muted: #8a94a4;
    --kn-landing-text-dim: #4a5060;
    --kn-landing-text-ghost: #1a1a22;
    --kn-landing-accent: #ca3a29;
    --kn-landing-accent-bright: #ff4e41;
    --kn-landing-accent-dim: rgba(202, 58, 41, 0.14);
    --kn-landing-border: rgba(192, 200, 212, 0.08);
    --kn-landing-border-hover: rgba(192, 200, 212, 0.16);
    --kn-landing-card-bg: rgba(192, 200, 212, 0.02);
    --kn-landing-glow-1: rgba(192, 200, 212, 0.07);
    --kn-landing-glow-2: rgba(202, 58, 41, 0.06);
    --kn-landing-star-color: #c0c8d4;
    --kn-landing-thread-white: rgba(192, 200, 212, 0.06);
    --kn-landing-thread-accent: rgba(202, 58, 41, 0.1);
    --kn-landing-thread-ocean: rgba(192, 200, 212, 0.04);
    --kn-landing-nav-link: #8a94a4;
    --kn-landing-nav-solid-bg: rgba(5, 5, 7, 0.88);
    --kn-landing-pill-bg: rgba(192, 200, 212, 0.03);
    --kn-landing-pill-border: rgba(192, 200, 212, 0.08);
    --kn-landing-footer-link: #ca3a29;
    --kn-landing-footer-link-hover: #ff4e41;
    --kn-landing-ico-bg: rgba(192, 200, 212, 0.04);
    --kn-landing-status-green: #00d4aa;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    color-scheme: dark;
    scroll-behavior: smooth;
  }

  body {
    background: var(--kn-landing-bg);
    color: var(--kn-landing-text);
    font-family: "DM Sans Variable", "DM Sans", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    min-height: 100vh;
    overflow-x: hidden;
  }

  body::after {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    opacity: 0.05;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    z-index: 1;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  .content-wrap,
  .main-inner {
    width: 100%;
    max-width: min(var(--marketing-content-max), 100%);
    margin-inline: auto;
  }

  .kn-root {
    position: relative;
    min-height: 100vh;
    background: var(--kn-landing-bg);
    color: var(--kn-landing-text-secondary);
    overflow-x: hidden;
  }

  .kn-root::before {
    content: "";
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 70% 55% at 50% 22%, var(--kn-landing-glow-1) 0%, transparent 72%),
      radial-gradient(ellipse 90% 60% at 50% 36%, var(--kn-landing-glow-2) 0%, transparent 78%),
      radial-gradient(ellipse 100% 50% at 50% 100%, rgba(0,0,0,0.32) 0%, transparent 70%);
  }

  .main {
    position: relative;
    z-index: 1;
    flex: 1;
    width: 100%;
    padding-inline: var(--marketing-pad-x);
  }

  .main-inner {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 20;
    width: 100%;
    transition: background 0.3s ease, backdrop-filter 0.3s ease, border-color 0.3s ease;
    border-bottom: 1px solid transparent;
  }

  .site-header.is-solid {
    background: var(--kn-landing-nav-solid-bg);
    backdrop-filter: blur(18px) saturate(150%);
    border-bottom-color: var(--kn-landing-border);
    box-shadow: 0 12px 44px rgba(0, 0, 0, 0.34);
  }

  .kn-nav-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.25rem var(--marketing-pad-x);
  }

  .kn-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--kn-landing-text);
    font-size: 0.96rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .nav-icon,
  .footer-icon {
    border-radius: 8px;
    box-shadow: 0 0 18px rgba(167, 139, 250, 0.12);
  }

  .kn-nav-links {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    flex-wrap: wrap;
  }

  .kn-nav-link {
    color: var(--kn-landing-nav-link);
    font-size: 0.84rem;
    transition: color 0.2s ease;
  }

  .kn-nav-link:hover {
    color: var(--kn-landing-text-secondary);
  }

  .kn-nav-signin,
  .hero-button,
  .secondary-button,
  .tab-chip,
  .spotlight-item,
  .faq-trigger {
    transition:
      transform 0.24s ease,
      border-color 0.24s ease,
      background 0.24s ease,
      color 0.24s ease,
      box-shadow 0.24s ease;
  }

  .kn-nav-signin,
  .secondary-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.55rem;
    min-height: 3rem;
    padding: 0.8rem 1.05rem;
    border-radius: 1rem;
    font-weight: 500;
    border: 1px solid var(--kn-landing-border);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0.02));
    color: rgba(232, 236, 240, 0.9);
    backdrop-filter: blur(18px);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
  }

  .kn-nav-signin:hover,
  .secondary-button:hover,
  .tab-chip:hover,
  .spotlight-item:hover,
  .faq-trigger:hover {
    transform: translateY(-1px);
    border-color: var(--kn-landing-border-hover);
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.24), 0 0 24px rgba(202, 58, 41, 0.08);
  }

  /* ── Skip link ── */

  .skip-link {
    position: absolute;
    top: -100%;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    padding: 0.75rem 1.5rem;
    border-radius: 0 0 var(--radius-md) var(--radius-md);
    background: var(--kn-landing-accent);
    color: #fff;
    font-weight: 600;
    font-size: 0.88rem;
    transition: top 0.2s ease;
  }

  .skip-link:focus {
    top: 0;
  }

  /* ── Mobile nav toggle ── */

  .kn-nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 10px;
    border: none;
    background: transparent;
    cursor: pointer;
  }

  .kn-nav-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    border-radius: 2px;
    background: var(--kn-landing-text-secondary);
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .kn-nav-toggle[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .kn-nav-toggle[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }

  .kn-nav-toggle[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── Active nav link ── */

  .kn-nav-link.is-active {
    color: var(--kn-landing-text);
  }

  .hero,
  .trust-strip,
  .feature-grid,
  .workflow-section,
  .spotlight,
  .theme-section,
  .faq-section,
  .final-cta,
  .final-cta-wrap {
    position: relative;
    z-index: 1;
    width: 100%;
  }

  .kn-stars,
  .kn-threads {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .kn-stars {
    opacity: 0.7;
  }

  .kn-threads-svg {
    width: 100%;
    height: 100%;
  }

  @keyframes kn-star-twinkle {
    0%, 100% { opacity: 0.12; }
    50% { opacity: 0.6; }
  }

  .kn-star-twinkle {
    animation: kn-star-twinkle 5s ease-in-out infinite;
  }

  .kn-thread {
    fill: none;
    stroke-linecap: round;
  }
  .kn-thread-a { stroke: var(--kn-landing-thread-white); stroke-width: 1.2; }
  .kn-thread-b { stroke: var(--kn-landing-thread-white); stroke-width: 0.9; opacity: 0.7; }
  .kn-thread-c { stroke: var(--kn-landing-thread-white); stroke-width: 0.8; opacity: 0.55; }
  .kn-thread-d { stroke: var(--kn-landing-thread-white); stroke-width: 0.7; opacity: 0.5; }
  .kn-thread-claw { stroke: var(--kn-landing-thread-accent); stroke-width: 1; }
  .kn-thread-claw-hi { stroke: var(--kn-landing-thread-accent); stroke-width: 0.8; opacity: 0.65; }
  .kn-thread-ocean { stroke: var(--kn-landing-thread-ocean); stroke-width: 0.9; }
  .kn-thread-ocean-hi { stroke: var(--kn-landing-thread-ocean); stroke-width: 0.7; opacity: 0.8; }
  .kn-dot { fill: var(--kn-landing-text-secondary); opacity: 0.25; }
  .kn-glow { fill: var(--kn-landing-accent); opacity: 0.06; }

  [data-reveal] {
    opacity: 0;
    transform: translateY(16px);
    transition:
      opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: opacity, transform;
  }

  [data-reveal].revealed {
    opacity: 1;
    transform: translateY(0);
  }

  [data-tab-panel] {
    opacity: 0;
    transform: translateY(8px);
    transition:
      opacity 0.35s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    position: absolute;
    inset: 0 auto auto 0;
    width: 100%;
    pointer-events: none;
    visibility: hidden;
  }

  [data-tab-panel][data-active="true"] {
    opacity: 1;
    transform: translateY(0);
    position: relative;
    pointer-events: auto;
    visibility: visible;
  }

  .kn-card,
  .feature-card,
  .workflow-card,
  .spotlight-panel,
  .theme-note,
  .theme-preview-card,
  .faq-card,
  .trust-item,
  .glass-stage,
  .meta-card,
  .panel,
  .rail,
  .final-cta {
    background: var(--kn-landing-card-bg);
    border: 1px solid var(--kn-landing-border);
    box-shadow:
      inset 0 1px 0 rgba(255, 255, 255, 0.04),
      0 24px 80px rgba(0, 0, 0, 0.34);
    backdrop-filter: blur(18px);
  }

  .kn-card:hover,
  .feature-card:hover,
  .workflow-card:hover,
  .spotlight-panel:hover,
  .theme-note:hover,
  .theme-preview-card:hover,
  .faq-card:hover,
  .trust-item:hover {
    border-color: var(--kn-landing-border-hover);
  }

  .eyebrow,
  .hero-pills span,
  .tab-chip,
  .spotlight-item,
  .faq-trigger,
  .workflow-step,
  .feature-eyebrow,
  .section-kicker,
  .trust-label,
  .theme-vibe,
  .meta-label,
  .floating-card-kicker {
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 0.72rem;
  }

  .kn-ico-wrap {
    width: 2.9rem;
    height: 2.9rem;
    border-radius: 1rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background: var(--kn-landing-ico-bg);
    border: 1px solid rgba(255, 255, 255, 0.06);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
    color: var(--kn-landing-accent-bright);
  }

  .section-title {
    font-size: clamp(2rem, 3vw, 3.15rem);
    line-height: 1.02;
    margin-top: 0.25rem;
    letter-spacing: -0.05em;
    text-wrap: balance;
  }

  .section-body,
  .feature-card p,
  .workflow-card p,
  .spotlight-panel p,
  .theme-note p,
  .faq-card p,
  .final-cta p,
  .subtagline,
  .other-platforms {
    color: rgba(245, 245, 245, 0.72);
    line-height: 1.7;
  }

  .hero-button {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.6rem;
    min-height: 3.4rem;
    padding: 0.95rem 1.2rem;
    border-radius: 1rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    overflow: hidden;
    color: #fff;
    border: 1px solid rgba(167, 139, 250, 0.3);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.1), rgba(255, 255, 255, 0.02)),
      linear-gradient(135deg, rgba(167, 139, 250, 0.3), rgba(124, 58, 237, 0.3));
    box-shadow:
      0 12px 48px rgba(167, 139, 250, 0.16),
      inset 0 1px 0 rgba(255,255,255,0.18);
  }

  .hero-button-shine {
    position: absolute;
    inset: -30% auto auto -20%;
    width: 45%;
    height: 180%;
    transform: rotate(24deg) translateX(0);
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent);
    pointer-events: none;
    transition: transform 0.45s ease;
  }

  .hero-button:hover {
    transform: translateY(-1px);
    border-color: rgba(196, 181, 253, 0.42);
    box-shadow: 0 14px 54px rgba(167, 139, 250, 0.22);
  }

  .hero-button:hover .hero-button-shine {
    transform: rotate(24deg) translateX(1.4rem);
  }

  .kn-footer {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--kn-landing-border);
    margin-top: 2rem;
    background: linear-gradient(180deg, rgba(255,255,255,0.01), rgba(255,255,255,0.02));
    backdrop-filter: blur(18px);
  }

  .section-divider {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    width: 100%;
    margin: 0 auto 4rem;
    color: rgba(192, 200, 212, 0.34);
  }

  .section-divider::before,
  .section-divider::after {
    content: "";
    flex: 1;
    max-width: 18rem;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(192, 200, 212, 0.12), transparent);
  }

  .section-divider svg {
    width: 2.2rem;
    height: 2.2rem;
    opacity: 0.82;
    filter: drop-shadow(0 0 16px rgba(202, 58, 41, 0.12));
  }

  .kn-footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 2rem var(--marketing-pad-x);
  }

  .kn-footer-mark {
    display: inline-flex;
