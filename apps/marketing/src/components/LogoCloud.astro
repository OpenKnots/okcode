      <span>Claude</span>
    </div>
    <div class="logo-cloud-item">
      <svg viewBox="0 0 24 24" fill="currentColor" width="32" height="32"><path d="M22.282 9.821a5.985 5.985 0 0 0-.516-4.91 6.046 6.046 0 0 0-6.51-2.9A6.065 6.065 0 0 0 4.981 4.18a5.985 5.985 0 0 0-3.998 2.9 6.046 6.046 0 0 0 .743 7.097 5.98 5.98 0 0 0 .51 4.911 6.051 6.051 0 0 0 6.515 2.9A5.985 5.985 0 0 0 13.26 24a6.056 6.056 0 0 0 5.772-4.206 5.99 5.99 0 0 0 3.997-2.9 6.056 6.056 0 0 0-.747-7.073zM13.26 22.43a4.476 4.476 0 0 1-2.876-1.04l.141-.081 4.779-2.758a.795.795 0 0 0 .392-.681v-6.737l2.02 1.168a.071.071 0 0 1 .038.052v5.583a4.504 4.504 0 0 1-4.494 4.494zM3.6 18.304a4.47 4.47 0 0 1-.535-3.014l.142.085 4.783 2.759a.771.771 0 0 0 .78 0l5.843-3.369v2.332a.08.08 0 0 1-.033.062L9.74 19.95a4.5 4.5 0 0 1-6.14-1.646zM2.34 7.896a4.485 4.485 0 0 1 2.366-1.973V11.6a.766.766 0 0 0 .388.676l5.815 3.355-2.02 1.168a.076.076 0 0 1-.071 0l-4.83-2.786A4.504 4.504 0 0 1 2.34 7.872zm16.597 3.855l-5.833-3.387L15.119 7.2a.076.076 0 0 1 .071 0l4.83 2.791a4.494 4.494 0 0 1-.676 8.105v-5.678a.79.79 0 0 0-.407-.667zm2.01-3.023l-.141-.085-4.774-2.782a.776.776 0 0 0-.785 0L9.409 9.23V6.897a.066.066 0 0 1 .028-.061l4.83-2.787a4.5 4.5 0 0 1 6.68 4.66zm-12.64 4.135l-2.02-1.164a.08.08 0 0 1-.038-.057V6.075a4.5 4.5 0 0 1 7.375-3.453l-.142.08L8.704 5.46a.795.795 0 0 0-.393.681zm1.097-2.365l2.602-1.5 2.602 1.5v3.001l-2.602 1.5-2.602-1.5z"/></svg>
      <span>OpenAI</span>
    </div>
    <div class="logo-cloud-item">
      <svg viewBox="0 0 24 24" fill="currentColor" width="32" height="32"><path d="M24 22.525H0l12-21.05 12 21.05z"/></svg>
      <span>Vercel</span>
    </div>
    <div class="logo-cloud-item">
      <svg viewBox="0 0 24 24" fill="currentColor" width="32" height="32"><path d="M4.105 4.105S9.158 1.58 11.684.316a3.079 3.079 0 0 1 1.481-.315c.766.047 1.677.788 1.677.788L24 9.948v9.789h-4.263V24H4.117l-.012-4.263H0v-9.789l4.105-5.843zM8.4 19.737h7.2V12h-7.2v7.737z"/></svg>
      <span>Terminal</span>
    </div>
  </div>
</section>

<style>
  .logo-cloud {
    text-align: center;
    margin-bottom: var(--kn-landing-section-gap, clamp(5rem, 8vw, 8rem));
    padding: 2rem 0;
  }

  .logo-cloud-label {
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--kn-landing-text-muted, #8a94a4);
    margin-bottom: 2.5rem;
  }

  .logo-cloud-grid {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .logo-cloud-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.65rem;
    color: var(--kn-landing-text-dim, #4a5060);
    transition: color 0.3s ease, transform 0.3s ease;
  }

  .logo-cloud-item:hover {
    color: var(--kn-landing-text-secondary, #c0c8d4);
    transform: translateY(-2px);
  }

  .logo-cloud-item svg {
    width: 2.25rem;
    height: 2.25rem;
    opacity: 0.35;
    transition: opacity 0.3s ease;
  }

  .logo-cloud-item:hover svg {
    opacity: 0.7;
  }

  .logo-cloud-item span {
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  @media (max-width: 720px) {
    .logo-cloud-grid {
      gap: 2rem;
    }
  }
</style>
