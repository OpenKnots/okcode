---
const regions = [
  { name: "North America", latency: "12ms", x: "20%", y: "35%" },
  { name: "Europe", latency: "18ms", x: "48%", y: "28%" },
  { name: "Asia Pacific", latency: "25ms", x: "75%", y: "40%" },
  { name: "South America", latency: "35ms", x: "30%", y: "65%" },
  { name: "Australia", latency: "30ms", x: "82%", y: "70%" },
];
---

<section id="global" class="relative py-24 sm:py-32 overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-primary/10 text-primary mb-4">
        Infrastructure
      </span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-foreground mb-4 text-balance">
        Global edge network
      </h2>
      <p class="max-w-2xl mx-auto text-lg text-muted-foreground text-balance">
        Lightning-fast responses from edge locations worldwide. Your AI assistant is always nearby.
      </p>
    </div>

    <!-- Globe Visualization -->
    <div class="relative aspect-[2/1] max-w-4xl mx-auto">
      <!-- Map background -->
      <div class="absolute inset-0 rounded-2xl glass overflow-hidden">
        <!-- Stylized world map using gradients -->
        <div class="absolute inset-0 opacity-20">
          <svg viewBox="0 0 1000 500" class="w-full h-full" preserveAspectRatio="xMidYMid slice">
            <!-- Simplified continent shapes -->
            <ellipse cx="200" cy="200" rx="120" ry="80" fill="currentColor" class="text-primary/50" />
            <ellipse cx="480" cy="180" rx="100" ry="70" fill="currentColor" class="text-primary/40" />
            <ellipse cx="750" cy="220" rx="150" ry="90" fill="currentColor" class="text-primary/30" />
            <ellipse cx="280" cy="350" rx="80" ry="60" fill="currentColor" class="text-primary/35" />
            <ellipse cx="820" cy="380" rx="70" ry="50" fill="currentColor" class="text-primary/25" />
          </svg>
        </div>

        <!-- Grid lines -->
        <div class="absolute inset-0 bg-[linear-gradient(rgba(139,92,246,0.05)_1px,transparent_1px),linear-gradient(90deg,rgba(139,92,246,0.05)_1px,transparent_1px)] bg-[size:50px_50px]"></div>

        <!-- Connection lines -->
        <svg class="absolute inset-0 w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
          <defs>
            <linearGradient id="line-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" style="stop-color:hsl(var(--primary));stop-opacity:0" />
              <stop offset="50%" style="stop-color:hsl(var(--primary));stop-opacity:0.5" />
              <stop offset="100%" style="stop-color:hsl(var(--primary));stop-opacity:0" />
            </linearGradient>
          </defs>
          <!-- Connection paths between regions -->
          <path d="M20,35 Q35,20 48,28" fill="none" stroke="url(#line-gradient)" stroke-width="0.2" />
          <path d="M48,28 Q62,35 75,40" fill="none" stroke="url(#line-gradient)" stroke-width="0.2" />
          <path d="M20,35 Q25,50 30,65" fill="none" stroke="url(#line-gradient)" stroke-width="0.2" />
          <path d="M75,40 Q78,55 82,70" fill="none" stroke="url(#line-gradient)" stroke-width="0.2" />
        </svg>

        <!-- Region markers -->
        {regions.map((region) => (
          <div 
            class="absolute transform -translate-x-1/2 -translate-y-1/2 group cursor-pointer"
            style={`left: ${region.x}; top: ${region.y};`}
          >
            <!-- Pulse ring -->
            <div class="absolute inset-0 w-4 h-4 -m-2 rounded-full bg-primary/30 animate-ping"></div>
            <!-- Core dot -->
            <div class="relative w-3 h-3 rounded-full bg-primary glow-primary"></div>
            <!-- Tooltip -->
            <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 px-3 py-2 rounded-lg bg-card border border-border opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap pointer-events-none">
              <div class="text-sm font-medium text-foreground">{region.name}</div>
              <div class="text-xs text-primary">{region.latency} latency</div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 mt-16">
      <div class="text-center p-6 rounded-xl glass">
        <div class="text-3xl font-bold text-foreground mb-2">50+</div>
        <div class="text-sm text-muted-foreground">Edge Locations</div>
      </div>
      <div class="text-center p-6 rounded-xl glass">
        <div class="text-3xl font-bold text-foreground mb-2">&lt;50ms</div>
        <div class="text-sm text-muted-foreground">Avg Response</div>
      </div>
      <div class="text-center p-6 rounded-xl glass">
        <div class="text-3xl font-bold text-foreground mb-2">99.99%</div>
        <div class="text-sm text-muted-foreground">Uptime SLA</div>
      </div>
      <div class="text-center p-6 rounded-xl glass">
        <div class="text-3xl font-bold text-foreground mb-2">6</div>
        <div class="text-sm text-muted-foreground">Continents</div>
      </div>
    </div>
  </div>
</section>
